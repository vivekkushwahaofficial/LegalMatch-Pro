# ==========================================
# LegalMatch Pro — Master .gitignore
# ==========================================

# Environment & Secret Files
.env
.env.development
.env.production
.env.local
.env.secrets
*.env.local
*.env.*.local

# ── Spring Boot & Maven ──
**/target/
**/*.class
**/*.jar
**/*.war
**/*.ear
hs_err_pid*
replay_pid*
.mvn/wrapper/maven-wrapper.jar

# ── React, Node & Frontend ──
**/node_modules/
**/dist/
**/dist-ssr/
**/build/
**/coverage/
.vite/
.npm
.eslintcache

# ── Docker ──
docker-compose.override.yml
*.docker-logs
docker/volumes/
**/pgdata/

# ── IDEs & System Files ──
.vscode/
!.vscode/extensions.json
.idea/
*.iml
*.ipr
*.iws
*.sw?
.DS_Store
Thumbs.db
desktop.ini

# ── Logs & Debugging ──
**/logs/
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Temporary Analysis, Reports & Documentation ──
project_analysis.md
implementation_plan.md
walkthrough.md
debug_notes.md
investigation_reports/
temporary_reports/
backend_logs_docker_err.txt

# Frontend env files
frontend/.env.local
frontend/.env.production.local

# Backend properties files
backend/src/main/resources/application-dev.properties
backend/src/main/resources/application-prod.properties


# OS files
$RECYCLE.BIN/
