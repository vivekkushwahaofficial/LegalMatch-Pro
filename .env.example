# ═══════════════════════════════════
# LegalMatch Pro — Environment Variables Template
# Copy this file to .env and configure local values.
# ═══════════════════════════════════

# Database Configurations
DB_PASSWORD=your_secure_db_password_here
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/legalmatch_db

# Security Configurations
# Must be a secure, random string of at least 32 characters for production
JWT_SECRET=your_jwt_secret_key_at_least_32_characters_here

# CORS Configurations
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
